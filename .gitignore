# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Node
node_modules/
.next/
out/
*.log
# TypeScript incremental build cache; regenerated on every `tsc` and causes
# pointless merge churn between branches.
tsconfig.tsbuildinfo

# Env
.env
.env.local

# Secrets (cookies, keys, etc.)
# We commit secrets/cookies.txt as an empty placeholder so the docker-compose
# bind mount always points at a real file. Local edits to it are ignored.
secrets/*
!secrets/cookies.txt
!secrets/cookies.txt.example
# Persistent Playwright browser profile maintained by the cookie-refresh
# service; contains the live YouTube session and must never be committed.
secrets/yt-state/

# Test artifacts (kept locally only)
test-plan.md
test-report.md

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# Build artifacts
dist/
build/
