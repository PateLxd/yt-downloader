# Backend
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_EXPIRE_MINUTES=1440
# Comma-separated user:password pairs (plaintext or bcrypt). Replace before exposing!
AUTH_USERS=admin:changeme

# Limits
RATE_LIMIT_PER_HOUR=5
MAX_CONCURRENT_JOBS=2
MAX_VIDEO_SECONDS=7200

# Storage
DOWNLOAD_DIR=/tmp/downloads
FILE_TTL_SECONDS=600

# Queue
REDIS_URL=redis://valkey:6379/0
QUEUE_NAME=downloads

# yt-dlp
# Path (inside the container) to a Netscape-format cookies.txt exported from a
# logged-in browser. Lets yt-dlp pass YouTube's "Sign in to confirm you're not
# a bot" challenge on flagged IPs. Drop your file at ./secrets/cookies.txt on
# the host — docker-compose mounts it read-only at /run/cookies.txt by default.
# Leave empty to disable.
YT_DLP_COOKIES_PATH=

# Runtime cookies override (paste-cookies-in-the-UI feature)
# How long a user-pasted cookies.txt stays active in Valkey before we fall
# back to the on-disk file at YT_DLP_COOKIES_PATH. 7 days by default. The
# cookie-refresh service (below) writes to this same key so refreshes also
# get the same TTL.
COOKIES_OVERRIDE_TTL_SECONDS=604800

# Cookie auto-refresh service (opt-in)
# Uncomment to launch the headless-Chromium service that keeps your YouTube
# cookies fresh on a schedule. Adds ~1.5 GB to your image pull. Leave commented
# out if you'd rather refresh cookies manually via the UI.
# COMPOSE_PROFILES=cookie-refresh

# How often (in seconds) the cookie-refresh service warms the YouTube session.
# Default 6 hours. Lower = fresher cookies + more YouTube traffic from your VPS.
COOKIE_REFRESH_INTERVAL_SECONDS=21600

# A short, safe-to-play YouTube URL the refresh service will visit each cycle
# to seed/extend the session cookies. Default is the first video ever uploaded
# to YouTube ("Me at the zoo") — public, ~19s, never going away.
COOKIE_REFRESH_TEST_VIDEO_URL=https://www.youtube.com/watch?v=jNQXAC9IVRw

# CORS (only matters for direct backend access, not behind nginx)
CORS_ORIGINS=*
