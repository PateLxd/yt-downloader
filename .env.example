# Backend
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_EXPIRE_MINUTES=1440
# Comma-separated user:password pairs (plaintext or bcrypt). Replace before exposing!
AUTH_USERS=admin:changeme

# Limits
RATE_LIMIT_PER_HOUR=5
MAX_CONCURRENT_JOBS=2
MAX_VIDEO_SECONDS=7200

# Storage
DOWNLOAD_DIR=/tmp/downloads
FILE_TTL_SECONDS=600

# Queue
REDIS_URL=redis://valkey:6379/0
QUEUE_NAME=downloads

# yt-dlp
# Path (inside the container) to a Netscape-format cookies.txt exported from a
# logged-in browser. Lets yt-dlp pass YouTube's "Sign in to confirm you're not
# a bot" challenge on flagged IPs. Drop your file at ./secrets/cookies.txt on
# the host — docker-compose mounts it read-only at /run/cookies.txt by default.
# Leave empty to disable.
#
# IMPORTANT: if you *do* want cookies (you almost always do on a VPS), set
# this to `/run/cookies.txt` — not just drop the file there. An empty value
# means yt-dlp is never told to read the file, even if it exists.
YT_DLP_COOKIES_PATH=/run/cookies.txt

# bgutil POT (proof-of-origin token) provider. Set this when you're on
# a flagged datacenter IP and even valid cookies don't get past
# YouTube's bot challenge. Recommended setup:
#   COMPOSE_PROFILES=pot-provider          # starts the provider container
#   POT_PROVIDER_URL=http://pot-provider:4416
# Leave empty to disable. With this and `COMPOSE_PROFILES=pot-provider`
# both set, `docker compose up -d` brings up the bgutil provider and
# the backend/worker forward yt-dlp's POT requests to it.
POT_PROVIDER_URL=

# Comma-separated yt-dlp YouTube `player_client` rotation. Only applied
# when POT_PROVIDER_URL is set.
#
# Default of `mweb,tv_simply` follows yt-dlp's YouTube PO Token Guide:
#   "Use a PO Token Provider plugin to provide the mweb client with a
#    PO Token for GVS requests."
#   https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
#
# Older default was `web,web_safari,tv`; that combo stopped working in
# early 2026 (yt-dlp#15583, yt-dlp#15601): `tv` went LOGIN_REQUIRED,
# `web_safari` HLS started requiring JS, `web` only offers SABR-only
# formats the default selector can't combine. Symptom of the stale
# default is "Requested format is not available" even with a healthy
# POT provider generating tokens.
#
# Override with a custom comma-separated list, or set empty to fall
# back to yt-dlp's own default client rotation.
YT_DLP_PLAYER_CLIENTS=mweb,tv_simply

# Optional outbound proxy for yt-dlp. Set this when even cookies + POT
# can't pass YouTube's bot challenge — typically because your VPS IP is
# heavily flagged. A residential proxy (Webshare, IPRoyal, etc.) is the
# practical fix in that case. Examples:
#   YT_DLP_PROXY=http://user:pass@host:port
#   YT_DLP_PROXY=socks5://user:pass@host:port
# Leave empty to disable.
YT_DLP_PROXY=

# CORS (only matters for direct backend access, not behind nginx)
CORS_ORIGINS=*
